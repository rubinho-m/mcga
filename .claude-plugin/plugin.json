{
  "name": "mcga",
  "description": "Make Commits Great Again — write git commit messages in Donald Trump tweet style",
  "author": {
    "name": "rubinho-m",
    "url": "https://github.com/rubinho-m/mcga"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/mcga-activate.js\"",
            "timeout": 5,
            "statusMessage": "Making commits great again..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/mcga-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "MCGA active..."
          }
        ]
      }
    ]
  }
}
